  "flows": [
    {
      "feature": "auth",
      "label": "用户登录流程",
      "edges": [
        {
          "from": "终端用户",
          "to": "商城前端",
          "label": "1. 输入账号密码并提交登录"
        },
        {
          "from": "商城前端",
          "to": "API网关",
          "label": "2. 发送认证请求"
        },
        {
          "from": "API网关",
          "to": "认证接口",
          "label": "3. 路由到认证接口"
        },
        {
          "from": "认证接口",
          "to": "登录认证用例",
          "label": "4. 执行登录认证用例"
        },
        {
          "from": "登录认证用例",
          "to": "账户服务",
          "label": "5. 校验账户状态与凭证"
        },
        {
          "from": "账户服务",
          "to": "账户仓储",
          "label": "6. 查询账户数据"
        },
        {
          "from": "账户仓储",
          "to": "用户账户库",
          "label": "7. 读取用户账户记录"
        }
      ]
    },
    {
